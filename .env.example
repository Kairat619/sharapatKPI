# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# GEMINI_API_KEY: Required only if using Gemini AI API features.
# Not currently used by the app but may be needed for future AI integrations.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this app is hosted (used for OAuth callbacks, etc.).
APP_URL="http://localhost:3000"

# DISABLE_HMR: Set to "true" to disable Hot Module Replacement (useful in AI Studio).
# DISABLE_HMR="true"
